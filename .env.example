# Telegram Bot API. Needed for the bot service.
TELEGRAM_BOT_TOKEN=

# Telegram user account parser. Create api_id/api_hash at https://my.telegram.org.
TELETHON_API_ID=
TELETHON_API_HASH=
TELETHON_PHONE=
TELETHON_SESSION_FILE=/app/data/telethon_session.session

# LM Studio. Use the base server URL without /v1 or /api/v1.
LM_STUDIO_BASE_URL=http://10.77.77.2:29931
LM_STUDIO_API_TOKEN=
LM_STUDIO_MODEL=
LM_STUDIO_API_MODE=native
LLM_TEMPERATURE=0.2
LLM_MAX_OUTPUT_TOKENS=2048
LLM_CONTEXT_LENGTH=8192

# Runtime paths inside Docker.
DATA_DIR=/app/data
LOGS_DIR=/app/logs
DATABASE_PATH=/app/data/news_bot.db
CHANNELS_JSON_PATH=/app/data/channels.json

# Periodic parsing in the bot service. Manual parsing is available in the panel.
AUTO_PARSE_ENABLED=false
CHECK_INTERVAL_SECONDS=3600
AUTO_PARSE_LIMIT=200
AUTO_PARSE_DAYS=7

# Parsers.
PARSER_PRIORITY=["telethon","rss","web"]
RSS_PARSER_TIMEOUT=15
WEB_PARSER_ENGINE=playwright
WEB_PARSER_HEADLESS=true
WEB_PARSER_TIMEOUT=30

LOG_LEVEL=INFO
